  "keyFeatures": [
    "Mine-to-Launch: community earns 95% of token supply by writing funny posts",
    "Auto-graduation: fully-mined tokens automatically open as a constant-product AMM (x*y=k)",
    "Built-in DEX: no external exchange needed — buy and sell tokens in the same contract",
    "Fee-seeded liquidity: ARC fees paid during mining become the initial DEX liquidity pool",
    "Zero backend: fully onchain dApp with no server, no database, no admin keys",
    "Per-wallet cooldown and daily mining cap enforced entirely in smart contracts",
    "ARC fee refunds available to miners before token graduation",
    "Token creator sets supply, mine amount, cooldown, and fee per mine",
    "Activity feed and miner leaderboard on each token page",
    "Live price chart for graduated tokens"
  ],
  "publicApiSurface": [
    "LaunchpadFactory.createToken(name, symbol, imageUri, maxSupply, mineAmount, cooldown, dailyMax, feePerMine)",
    "LaunchpadFactory.getTokens(from, count)",
    "LaunchpadFactory.getToken(index)",
    "LaunchpadFactory.getTokenCount()",
    "TokenLauncher.mine(funnyPost)",
    "TokenLauncher.buyTokens(minTokensOut)",
    "TokenLauncher.sellTokens(tokenAmount, minArcOut)",
    "TokenLauncher.claimRefund()",
